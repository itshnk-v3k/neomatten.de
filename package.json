{
  "name": "neomatten",
  "version": "0.0.1",
  "description": "NEOMATTEN — custom EVA car-mat e-commerce frontend (Angular).",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --configuration development --host 0.0.0.0",
    "start:staging": "ng serve --configuration staging --host 0.0.0.0 --proxy-config proxy.staging.conf.json",
    "start:prod": "ng build --configuration production && npx serve dist/neomatten/browser",
    "build": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "build:staging": "ng build --configuration staging",
    "watch": "ng build --watch --configuration development",
    "build:data": "node scripts/build-vehicle-data.mjs",
    "optimize:images": "node scripts/optimize-images.mjs",
    "test": "ng test",
    "lint": "ng lint && npm run lint:styles",
    "lint:styles": "node scripts/check-no-ng-deep.mjs",
    "lint:fix": "ng lint --fix",
    "format": "prettier --write \"src/**/*.{ts,html,scss,json}\"",
    "format:check": "prettier --check \"src/**/*.{ts,html,scss,json}\""
  },
  "type": "module",
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@lucide/angular": "^1.18.0",
    "@stripe/stripe-js": "^9.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-angular": "^22.0.0",
    "embla-carousel-autoplay": "^8.6.0",
    "embla-carousel-class-names": "^8.6.0",
    "embla-carousel-wheel-gestures": "^8.1.0",
    "leaflet": "^1.9.4",
    "libphonenumber-js": "^1.12.41",
    "ngx-cookie-service": "^22.0.0",
    "ngx-sonner": "^3.1.0",
    "rxjs": "~7.8.2",
    "simple-icons": "^16.23.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "zone.js": "~0.16.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.1",
    "@eslint/js": "^10.0.1",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^25.5.0",
    "angular-eslint": "^22.0.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.0.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "jsdom": "^29.0.1",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sharp": "^0.35.1",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.2"
  }
}
