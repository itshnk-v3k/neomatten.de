// NEOMATTEN backend — Prisma schema.
// One source of truth for the PostgreSQL data model; mirrors the shared DTOs
// in projects/neomatten-shared so one shape travels FE ⇄ API ⇄ DB.

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

/// Order lifecycle status. Mirrors `OrderStatus` in neomatten-shared.
enum OrderStatus {
  REVIEW
  PENDING
  IN_PRODUCTION
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

/// Account / auth profile. Supports both local (email + password) accounts and
/// OAuth accounts (Google / Facebook). OAuth-created accounts have no password
/// (`passwordHash` null); a single account can link multiple provider ids after
/// email-match linking. `authProvider` records the primary signup method.
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String?
  firstName    String
  lastName     String
  phone        String?
  isAdmin      Boolean  @default(false)
  /// Google OAuth subject id (set when a Google account is linked).
  googleId     String?  @unique
  /// Facebook OAuth user id (set when a Facebook account is linked).
  facebookId   String?  @unique
  /// Primary signup method: "local" | "google" | "facebook".
  authProvider String   @default("local")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orders    Order[]
  auditLogs AuditLog[]

  @@map("users")
}

/// A customer order — header + money totals + lifecycle status.
model Order {
  id         String      @id @default(uuid())
  userId     String?
  status     OrderStatus @default(REVIEW)
  totalPrice Decimal     @db.Decimal(10, 2)
  currency   String      @default("EUR")
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  user  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  items OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

/// A single ordered line. `configuration` holds the configurator selections
/// for custom mat sets; empty for simple catalogue products.
model OrderItem {
  id            String  @id @default(uuid())
  orderId       String
  productType   String
  configuration Json    @default("{}")
  quantity      Int     @default(1)
  unitPrice     Decimal @db.Decimal(10, 2)

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_items")
}

/// Catalogue product (simple, non-configured products + the mats family).
model Product {
  id        String   @id @default(uuid())
  slug      String   @unique
  type      String
  nameDE    String
  nameEN    String
  basePrice Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
  @@map("products")
}

/// Admin-editable key/value settings (feature flags, contact info, shipping…).
model Setting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@map("settings")
}

/// A single UI copy string, per key + locale, with a draft/publish workflow.
/// `value` is the live/published copy served to the public site; `draftValue`
/// holds a pending unpublished edit (null when there is no pending change).
/// The special Setting row `translationsPublishedAt` is bumped on every publish
/// so the public site can use it as a cache-bust signal.
model Translation {
  id         String   @id @default(cuid())
  key        String
  locale     String
  category   String?
  value      String   @db.Text
  draftValue String?  @db.Text
  /// Previous key, set on rename. The public endpoint keeps serving this key
  /// (aliased to the same value) during the transition until the codebase is
  /// synced. Overwritten on each rename — aliases are not chained.
  oldKey     String?
  updatedAt  DateTime @updatedAt

  @@unique([key, locale])
  @@index([locale])
  @@index([category])
  @@map("translations")
}

/// Append-only audit trail of admin / system actions.
model AuditLog {
  id        String   @id @default(uuid())
  action    String
  userId    String?
  details   Json     @default("{}")
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@map("audit_logs")
}
