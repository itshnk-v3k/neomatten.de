DATABASE_URL="postgresql://neomatten:password@localhost:5432/neomatten_db"
JWT_SECRET="change-me-in-production"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"
PORT=5000

# Password for the seeded admin@neomatten.de account (npx prisma db seed).
ADMIN_SEED_PASSWORD="admin12345"

# Public site base URL — OAuth callbacks redirect here (…/auth/callback?code=…).
FRONTEND_URL="http://localhost:4200"

# Google OAuth 2.0 — create credentials at https://console.cloud.google.com/apis/credentials
# (OAuth client ID → Web application). The authorized redirect URI must match GOOGLE_CALLBACK_URL.
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:5000/api/auth/google/callback"

# Facebook Login — create an app at https://developers.facebook.com/apps
# (Facebook Login product). The Valid OAuth Redirect URI must match FACEBOOK_CALLBACK_URL.
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:5000/api/auth/facebook/callback"
