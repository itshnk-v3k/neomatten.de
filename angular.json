{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false,
    "schematicCollections": [
      "@schematics/angular",
      "@angular-eslint/schematics"
    ],
    "cache": {
      "enabled": false
    }
  },
  "newProjectRoot": "projects",
  "projects": {
    "neomatten": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true,
          "skipTests": true,
          "changeDetection": "OnPush",
          "inlineTemplate": false,
          "inlineStyle": false,
          "type": "component"
        },
        "@schematics/angular:service": {
          "skipTests": true,
          "type": "service"
        },
        "@schematics/angular:pipe": {
          "standalone": true,
          "skipTests": true,
          "type": "pipe"
        },
        "@schematics/angular:guard": {
          "skipTests": true,
          "type": "guard"
        },
        "@schematics/angular:directive": {
          "standalone": true,
          "skipTests": true,
          "type": "directive"
        },
        "@schematics/angular:interceptor": {
          "skipTests": true,
          "type": "interceptor"
        },
        "@schematics/angular:resolver": {
          "skipTests": true,
          "type": "resolver"
        }
      },
      "root": "projects/neomatten-app",
      "sourceRoot": "projects/neomatten-app/src",
      "prefix": "nm",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/neomatten",
            "index": "projects/neomatten-app/src/index.html",
            "browser": "projects/neomatten-app/src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "projects/neomatten-app/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "allowedCommonJsDependencies": [
              "leaflet"
            ],
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/neomatten-app/src/assets/i18n",
                "output": "assets/i18n"
              },
              {
                "glob": "**/*",
                "input": "projects/neomatten-app/src/assets/images",
                "output": "assets/images"
              },
              {
                "glob": "**/*",
                "input": "projects/neomatten-app/src/assets/data",
                "output": "assets/data"
              },
              {
                "glob": "**/*",
                "input": "projects/neomatten-app/src/assets/docs",
                "output": "assets/docs"
              },
              {
                "glob": "**/*",
                "input": "projects/neomatten-app/src/assets/configurator",
                "output": "assets/configurator"
              },
              {
                "glob": "robots.txt",
                "input": "projects/neomatten-app/src",
                "output": "/"
              },
              {
                "glob": "sitemap.xml",
                "input": "projects/neomatten-app/src",
                "output": "/"
              },
              {
                "glob": "manifest.webmanifest",
                "input": "projects/neomatten-app/src",
                "output": "/"
              }
            ],
            "styles": [
              "projects/neomatten-app/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "projects/neomatten-app/src/environments/environment.ts",
                  "with": "projects/neomatten-app/src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "6mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "outputHashing": "all",
              "optimization": true,
              "sourceMap": false,
              "extractLicenses": true
            },
            "staging": {
              "fileReplacements": [
                {
                  "replace": "projects/neomatten-app/src/environments/environment.ts",
                  "with": "projects/neomatten-app/src/environments/environment.staging.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "6mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "outputHashing": "all",
              "optimization": true,
              "sourceMap": true,
              "extractLicenses": true
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "projects/neomatten-app/src/environments/environment.ts",
                  "with": "projects/neomatten-app/src/environments/environment.dev.ts"
                }
              ],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "neomatten:build:production"
            },
            "staging": {
              "buildTarget": "neomatten:build:staging"
            },
            "development": {
              "buildTarget": "neomatten:build:development",
              "proxyConfig": "proxy.conf.json"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/neomatten-app/src/**/*.ts",
              "projects/neomatten-app/src/**/*.html"
            ]
          }
        }
      }
    },
    "neomatten-shared": {
      "projectType": "library",
      "root": "projects/neomatten-shared",
      "sourceRoot": "projects/neomatten-shared/src",
      "prefix": "nm-shared",
      "architect": {
        "build": {
          "builder": "@angular/build:ng-packagr",
          "configurations": {
            "production": {
              "tsConfig": "projects/neomatten-shared/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/neomatten-shared/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular/build:unit-test",
          "options": {
            "tsConfig": "projects/neomatten-shared/tsconfig.spec.json"
          }
        }
      }
    },
    "neomatten-admin": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss"
        }
      },
      "root": "projects/neomatten-admin",
      "sourceRoot": "projects/neomatten-admin/src",
      "prefix": "na",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/neomatten-admin/src/main.ts",
            "tsConfig": "projects/neomatten-admin/tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/neomatten-admin/public"
              }
            ],
            "styles": [
              "projects/neomatten-admin/src/styles.scss"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "4kB",
                  "maximumError": "8kB"
                }
              ],
              "outputHashing": "all",
              "serviceWorker": "projects/neomatten-admin/ngsw-config.json",
              "fileReplacements": [
                {
                  "replace": "projects/neomatten-admin/src/environments/environment.ts",
                  "with": "projects/neomatten-admin/src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "neomatten-admin:build:production"
            },
            "development": {
              "buildTarget": "neomatten-admin:build:development",
              "proxyConfig": "projects/neomatten-admin/proxy.conf.json"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "projects/neomatten-admin/src/**/*.ts",
              "projects/neomatten-admin/src/**/*.html"
            ]
          }
        }
      }
    }
  }
}
