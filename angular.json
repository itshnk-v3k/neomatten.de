{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "analytics": false,
    "schematicCollections": ["@schematics/angular", "@angular-eslint/schematics"],
    "cache": {
      "enabled": false
    }
  },
  "newProjectRoot": "projects",
  "projects": {
    "neomatten": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": true,
          "skipTests": true,
          "changeDetection": "OnPush",
          "inlineTemplate": false,
          "inlineStyle": false,
          "type": "component"
        },
        "@schematics/angular:service": {
          "skipTests": true,
          "type": "service"
        },
        "@schematics/angular:pipe": {
          "standalone": true,
          "skipTests": true,
          "type": "pipe"
        },
        "@schematics/angular:guard": {
          "skipTests": true,
          "type": "guard"
        },
        "@schematics/angular:directive": {
          "standalone": true,
          "skipTests": true,
          "type": "directive"
        },
        "@schematics/angular:interceptor": {
          "skipTests": true,
          "type": "interceptor"
        },
        "@schematics/angular:resolver": {
          "skipTests": true,
          "type": "resolver"
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "nm",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "outputPath": "dist/neomatten",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "allowedCommonJsDependencies": ["leaflet"],
            "assets": [
              {
                "glob": "**/*",
                "input": "src/assets",
                "output": "assets"
              },
              { "glob": "robots.txt", "input": "src", "output": "/" },
              { "glob": "sitemap.xml", "input": "src", "output": "/" },
              { "glob": "manifest.webmanifest", "input": "src", "output": "/" }
            ],
            "styles": ["src/styles.scss"]
          },
          "configurations": {
            "production": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.prod.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "6mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "outputHashing": "all",
              "optimization": true,
              "sourceMap": false,
              "extractLicenses": true
            },
            "staging": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.staging.ts"
                }
              ],
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "4mb",
                  "maximumError": "6mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "40kB"
                }
              ],
              "outputHashing": "all",
              "optimization": true,
              "sourceMap": true,
              "extractLicenses": true
            },
            "development": {
              "fileReplacements": [
                {
                  "replace": "src/environments/environment.ts",
                  "with": "src/environments/environment.dev.ts"
                }
              ],
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "neomatten:build:production"
            },
            "staging": {
              "buildTarget": "neomatten:build:staging"
            },
            "development": {
              "buildTarget": "neomatten:build:development",
              "proxyConfig": "proxy.conf.json"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        },
        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
          }
        }
      }
    }
  }
}
